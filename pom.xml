<?xml version="1.0" encoding="UTF-8"?>
<!--
  pom.xml
  Root Maven POM for Apigee proxy: proxy-demo-maven
  Uses: apigee-deploy-maven-plugin (Apigee X / hybrid)

  Authentication  : Google OAuth2 access token (injected by GitHub Actions WIF)
  Target org      : ${apigee.org}    (set via -Dapigee.org=... or CI secret)
  Target env      : ${apigee.env}    (set via -Dapigee.env=... or CI secret)
  Proxy bundle dir: apiproxy/        (standard flat layout, no src/gateway wrapper)
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- ── Project coordinates ──────────────────────────────────────────── -->
    <groupId>com.example.apigee</groupId>
    <artifactId>proxy-demo-maven</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>

    <name>proxy-demo-maven</name>
    <description>Apigee API proxy deployed via Maven plugin from GitHub Actions</description>

    <!-- ── Properties ───────────────────────────────────────────────────── -->
    <properties>
        <!-- Overridden at runtime via -D flags or CI environment variables  -->
        <apigee.org>${env.APIGEE_ORG}</apigee.org>
        <apigee.env>${env.APIGEE_ENV}</apigee.env>

        <!-- Token injected by google-github-actions/auth (WIF keyless flow) -->
        <apigee.googletoken>${env.APIGEE_TOKEN}</apigee.googletoken>

        <!-- Proxy bundle root — flat layout used by this repo              -->
        <apigee.apitype>apiproxy</apigee.apitype>
        <apigee.proxy.basedir>.</apigee.proxy.basedir>

        <!-- Plugin version -->
        <apigee.maven.plugin.version>2.4.2</apigee.maven.plugin.version>

        <!-- Encoding -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <!-- ── Build ────────────────────────────────────────────────────────── -->
    <build>
        <plugins>

            <!-- ── Apigee Deploy Maven Plugin ──────────────────────────── -->
            <plugin>
                <groupId>com.apigee.edge.partners</groupId>
                <artifactId>apigee-deploy-maven-plugin</artifactId>
                <version>${apigee.maven.plugin.version}</version>

                <executions>
                    <execution>
                        <id>deploy-proxy</id>

                        <!--
                          "deploy" phase bundles + imports + deploys in one shot.
                          Equivalent to running:
                            mvn apigee-enterprise:deploy
                        -->
                        <phase>install</phase>

                        <goals>
                            <goal>deploy</goal>
                        </goals>

                        <configuration>

                            <!-- Apigee X / hybrid org and environment -->
                            <apigeeOrg>${apigee.org}</apigeeOrg>
                            <apigeeEnv>${apigee.env}</apigeeEnv>

                            <!--
                              authType = "googleidtoken" uses the short-lived
                              Google OAuth2 access token from WIF — no JSON key.
                            -->
                            <authType>googleidtoken</authType>
                            <googleTokenEmail>${apigee.googletoken}</googleTokenEmail>

                            <!-- Where the apiproxy/ folder lives            -->
                            <apigeeBasePath>${apigee.proxy.basedir}</apigeeBasePath>

                            <!-- Override existing deployment revision        -->
                            <override>true</override>

                            <!-- Wait until deployment state = READY          -->
                            <delay>5000</delay>

                        </configuration>
                    </execution>
                </executions>
            </plugin>

        </plugins>
    </build>

    <!-- ── Plugin repository (Apigee Maven plugin is hosted on GitHub PKG) -->
    <pluginRepositories>
        <pluginRepository>
            <id>central</id>
            <url>https://repo1.maven.org/maven2</url>
            <releases><enabled>true</enabled></releases>
            <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>
        <pluginRepository>
            <id>apigee-deploy-plugin</id>
            <url>https://github.com/apigee/apigee-deploy-maven-plugin/releases</url>
            <releases><enabled>true</enabled></releases>
            <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>
    </pluginRepositories>

</project>
