<?xml version="1.0" encoding="UTF-8"?>
<!--
  pom.xml
  Root Maven POM for Apigee proxy: proxy-demo-maven

  Plugin  : apigee-edge-maven-plugin v2.5.2
  GroupId : io.apigee.build-tools.enterprise4g        (correct — on Maven Central)
  Source  : https://github.com/apigee/apigee-deploy-maven-plugin
  Repo    : Maven Central (no GitHub Packages, no credentials needed)

  Version guide:
    2.x  →  Apigee X / hybrid  (this file)
    1.x  →  Apigee Edge SaaS / Private Cloud OPDK
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- ── Project coordinates ──────────────────────────────────────────── -->
    <groupId>apigee</groupId>
    <artifactId>proxy-demo-maven</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>
    <name>proxy-demo-maven</name>
    <description>Apigee API proxy deployed via Maven plugin from GitHub Actions</description>

    <!-- ── Properties ───────────────────────────────────────────────────── -->
    <properties>
        <!-- Passed in via -D flags from the workflow mvn command -->
        <apigee.org>${env.APIGEE_ORG}</apigee.org>
        <apigee.env>${env.APIGEE_ENV}</apigee.env>

        <!--
          bearer token from WIF (google-github-actions/auth access_token output).
          Passed in via -Dbearer=... on the mvn command line.
        -->
        <apigee.bearer>${bearer}</apigee.bearer>

        <!-- Plugin version — 2.x for Apigee X / hybrid -->
        <apigee.plugin.version>2.5.2</apigee.plugin.version>

        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <!-- ── Build ────────────────────────────────────────────────────────── -->
    <build>
        <plugins>
            <plugin>
                <!--
                  CORRECT coordinates for Apigee X/hybrid Maven plugin
                  on Maven Central — no extra repository config needed.

                  groupId    : io.apigee.build-tools.enterprise4g
                  artifactId : apigee-edge-maven-plugin
                  version    : 2.5.2  (latest 2.x on Maven Central)
                -->
                <groupId>io.apigee.build-tools.enterprise4g</groupId>
                <artifactId>apigee-edge-maven-plugin</artifactId>
                <version>${apigee.plugin.version}</version>

                <executions>
                    <execution>
                        <id>deploy-proxy</id>
                        <phase>install</phase>
                        <goals>
                            <goal>configure</goal>
                            <goal>deploy</goal>
                        </goals>

                        <configuration>
                            <!-- Apigee X org and environment -->
                            <apigeeOrg>${apigee.org}</apigeeOrg>
                            <apigeeEnv>${apigee.env}</apigeeEnv>

                            <!--
                              bearer token auth — uses the short-lived WIF
                              access token. No JSON key stored anywhere.
                              Equivalent to: gcloud auth print-access-token
                            -->
                            <apigeeAPIVersion>apigee</apigeeAPIVersion>
                            <bearer>${apigee.bearer}</bearer>

                            <!-- Override (undeploy) existing revision -->
                            <apigeeOptions>override</apigeeOptions>

                            <!-- Wait for deployment to reach READY state -->
                            <apigeeDelay>5000</apigeeDelay>

                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <!-- ── Plugin repositories ───────────────────────────────────────────
         Only Maven Central needed — plugin is published there directly.
         No GitHub Packages, no credentials, no settings.xml required.
    ──────────────────────────────────────────────────────────────────── -->
    <pluginRepositories>
        <pluginRepository>
            <id>central</id>
            <name>Maven Central</name>
            <url>https://repo1.maven.org/maven2</url>
            <releases><enabled>true</enabled></releases>
            <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>
    </pluginRepositories>

</project>
