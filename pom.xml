<?xml version="1.0" encoding="UTF-8"?>
<!--
  pom.xml
  Root Maven POM for Apigee proxy: proxy-demo-maven
  Plugin : apigee-deploy-maven-plugin v2.4.2
  Source : https://github.com/apigee/apigee-deploy-maven-plugin (GitHub Packages)
  Auth   : Google OAuth2 access token via WIF (keyless — no JSON key)
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- ── Project coordinates ──────────────────────────────────────────── -->
    <groupId>com.example.apigee</groupId>
    <artifactId>proxy-demo-maven</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>

    <name>proxy-demo-maven</name>
    <description>Apigee API proxy deployed via Maven plugin from GitHub Actions</description>

    <!-- ── Properties ───────────────────────────────────────────────────── -->
    <properties>
        <apigee.org>${env.APIGEE_ORG}</apigee.org>
        <apigee.env>${env.APIGEE_ENV}</apigee.env>
        <apigee.googletoken>${env.APIGEE_TOKEN}</apigee.googletoken>
        <apigee.proxy.basedir>.</apigee.proxy.basedir>
        <apigee.apitype>apiproxy</apigee.apitype>

        <!--
          Plugin is fetched from GitHub Packages.
          The GITHUB_TOKEN injected by Actions is used as the password
          in settings.xml (written by the workflow step below).
        -->
        <apigee.maven.plugin.version>2.4.2</apigee.maven.plugin.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <!-- ── Build ────────────────────────────────────────────────────────── -->
    <build>
        <plugins>
            <plugin>
                <groupId>com.apigee.edge.partners</groupId>
                <artifactId>apigee-deploy-maven-plugin</artifactId>
                <version>${apigee.maven.plugin.version}</version>

                <executions>
                    <execution>
                        <id>deploy-proxy</id>
                        <phase>install</phase>
                        <goals>
                            <goal>deploy</goal>
                        </goals>

                        <configuration>
                            <apigeeOrg>${apigee.org}</apigeeOrg>
                            <apigeeEnv>${apigee.env}</apigeeEnv>

                            <!--
                              googleidtoken  → uses the short-lived WIF access token.
                              No JSON key stored anywhere.
                            -->
                            <authType>googleidtoken</authType>
                            <googleTokenEmail>${apigee.googletoken}</googleTokenEmail>

                            <apigeeBasePath>${apigee.proxy.basedir}</apigeeBasePath>
                            <apitype>${apigee.apitype}</apitype>

                            <!-- Undeploy the previous revision before deploying -->
                            <override>true</override>

                            <!-- Wait 5 s for Apigee to reach READY state -->
                            <delay>5000</delay>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <!-- ── Plugin repository ─────────────────────────────────────────────
         The plugin jar lives on GitHub Packages, not Maven Central.
         Maven reads credentials for this repo from ~/.m2/settings.xml
         which the workflow writes before running mvn install.
    ──────────────────────────────────────────────────────────────────── -->
    <pluginRepositories>

        <pluginRepository>
            <id>central</id>
            <url>https://repo1.maven.org/maven2</url>
            <releases><enabled>true</enabled></releases>
            <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>

        <!--
          id must match the <server> id in settings.xml written by the workflow.
        -->
        <pluginRepository>
            <id>apigee-deploy-maven-plugin</id>
            <url>https://maven.pkg.github.com/apigee/apigee-deploy-maven-plugin</url>
            <releases><enabled>true</enabled></releases>
            <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>

    </pluginRepositories>

</project>
